{
  "name": "medlearn-cloud-worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude test/runtime.integration.test.ts && npm run test:runtime",
    "test:runtime": "wrangler deploy --dry-run --outdir .runtime-test && vitest run test/runtime.integration.test.ts",
    "contracts:generate": "node scripts/generate-intake-validator.mjs",
    "contracts:check": "node scripts/check-contracts.mjs",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@types/node": "^24.0.0",
    "@eslint/js": "^9.30.1",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "eslint": "^9.30.1",
    "miniflare": "4.20260708.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "4.1.0",
    "wrangler": "4.110.0"
  }
}
