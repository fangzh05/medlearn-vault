{
  "$defs": {
    "ManifestArtifact": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "media_type": {
          "title": "Media Type",
          "type": "string"
        },
        "content_digest": {
          "title": "Content Digest",
          "type": "string"
        },
        "byte_length": {
          "exclusiveMinimum": 0,
          "title": "Byte Length",
          "type": "integer"
        },
        "capture_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Capture Id"
        },
        "publication_plan_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Publication Plan Id"
        },
        "presentation_generation_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Presentation Generation Id"
        },
        "storage_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Storage Key"
        }
      },
      "required": [
        "path",
        "media_type",
        "content_digest",
        "byte_length"
      ],
      "title": "ManifestArtifact",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "manifest_version": {
      "enum": [
        "0.1.0",
        "0.2.0",
        "0.3.0"
