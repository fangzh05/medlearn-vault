{
  "$defs": {
    "PresentationArtifact": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "storage_key": {
          "title": "Storage Key",
          "type": "string"
        },
        "media_type": {
          "default": "text/markdown; charset=utf-8",
          "title": "Media Type",
          "type": "string"
        },
        "content_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Content Digest",
          "type": "string"
        },
        "byte_length": {
          "exclusiveMinimum": 0,
          "title": "Byte Length",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "storage_key",
        "content_digest",
        "byte_length"
      ],
      "title": "PresentationArtifact",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "presentation_version": {
      "default": "1.0.0",
      "title": "Presentation Version",
      "type": "string"
    },
    "renderer_version": {
      "default": "1.0.0",
      "title": "Renderer Version",
      "type": "string"
    },
    "presentation_generation_id": {
      "pattern": "^presentation_[a-f0-9]{32}$",
      "title": "Presentation Generation Id",
      "type": "string"
    },
    "active_bundle_digest": {
      "pattern": "^sha256:[a-f0-9]{64}$",
      "title": "Active Bundle Digest",
      "type": "string"
    },
    "publication_receipt_digests": {
      "items": {
        "type": "string"
      },
      "title": "Publication Receipt Digests",
      "type": "array"
    },
    "artifacts": {
      "items": {
        "$ref": "#/$defs/PresentationArtifact"
      },
      "title": "Artifacts",
      "type": "array"
    }
  },
  "required": [
    "presentation_generation_id",
    "active_bundle_digest",
    "publication_receipt_digests",
    "artifacts"
  ],
  "title": "PresentationGenerationReceipt",
  "type": "object"
}
