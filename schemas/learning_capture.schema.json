{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://medlearn.local/schemas/learning_capture.schema.json",
  "title": "LearningCapture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "source_id",
    "captured_at",
    "discipline_id",
    "concept_mentions",
    "learner_evidence",
    "misconceptions",
    "open_questions"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "session_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "discipline_id": {
      "type": "string"
    },
    "course_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "chapter_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "concept_mentions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "surface_text",
          "candidate_concept_ids",
          "resolution_status",
          "confidence"
        ],
        "properties": {
          "surface_text": {
            "type": "string"
          },
          "candidate_concept_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "resolved_concept_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "resolution_status": {
            "enum": [
              "resolved",
              "ambiguous",
              "new_candidate",
              "rejected"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "message_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "learner_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "concept_id",
          "evidence_type",
          "confidence",
          "rationale",
          "message_id",
          "observed_at"
        ],
        "properties": {
          "evidence_id": {
            "type": "string"
          },
          "concept_id": {
            "type": "string"
          },
          "knowledge_unit_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "evidence_type": {
            "enum": [
              "correct_independent",
              "correct_after_hint",
              "guessed_correct",
              "partial",
              "unknown",
              "incorrect",
              "high_confidence_incorrect",
              "self_report_only"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "rationale": {
            "type": "string"
          },
          "message_id": {
            "type": "string"
          },
          "observed_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "misconceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "misconception_id",
          "concept_ids",
          "error_logic",
          "correct_logic",
          "severity",
          "status",
          "source_message_ids"
        ],
        "properties": {
          "misconception_id": {
            "type": "string"
          },
          "concept_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "discipline_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "error_logic": {
            "type": "string"
          },
          "correct_logic": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "status": {
            "enum": [
              "active",
              "improving",
              "resolved",
              "relapsed"
            ]
          },
          "source_message_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "question_id",
          "text",
          "concept_ids",
          "priority"
        ],
        "properties": {
          "question_id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "concept_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "discipline_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "priority": {
            "enum": [
              "low",
              "medium",
              "high"
            ]
          }
        }
      }
    }
  }
}
