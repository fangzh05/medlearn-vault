{
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.2.0",
      "default": "1.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "relation_id": {
      "pattern": "^relation_[a-f0-9]{32}$",
      "title": "Relation Id",
      "type": "string"
    },
    "source_concept_id": {
      "pattern": "^concept_[a-f0-9]{32}$",
      "title": "Source Concept Id",
      "type": "string"
    },
    "relation_type": {
      "enum": [
        "subtype_of",
        "part_of",
        "associated_with",
        "may_cause",
        "may_be_complicated_by",
        "has_manifestation",
        "investigated_by",
        "diagnosed_by",
        "differential_with",
        "treated_by",
        "indicated_for",
        "contraindicated_with",
        "affects_anatomy",
        "measured_by",
        "biomarker_for"
      ],
      "title": "Relation Type",
      "type": "string"
    },
    "target_concept_id": {
      "pattern": "^concept_[a-f0-9]{32}$",
      "title": "Target Concept Id",
      "type": "string"
    },
    "supporting_claim_ids": {
      "default": [],
      "items": {
        "pattern": "^claim_[a-f0-9]{32}$",
        "type": "string"
      },
      "title": "Supporting Claim Ids",
      "type": "array"
    },
    "confidence": {
      "anyOf": [
        {
          "maximum": 1,
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Confidence"
    },
    "match_fingerprint": {
      "default": "",
      "pattern": "^relfp_[a-f0-9]{16}$",
      "title": "Match Fingerprint",
      "type": "string"
    }
  },
  "required": [
    "relation_id",
    "source_concept_id",
    "relation_type",
    "target_concept_id"
  ],
  "title": "ConceptRelation",
  "type": "object"
}
