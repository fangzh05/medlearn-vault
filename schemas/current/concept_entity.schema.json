{
  "$defs": {
    "ConceptAlias": {
      "additionalProperties": false,
      "properties": {
        "text": {
          "minLength": 1,
          "title": "Text",
          "type": "string"
        },
        "normalized": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Normalized"
        },
        "language": {
          "title": "Language",
          "type": "string"
        },
        "alias_type": {
          "enum": [
            "abbreviation",
            "translation",
            "synonym",
            "legacy",
            "trade_name",
            "other"
          ],
          "title": "Alias Type",
          "type": "string"
        },
        "source_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Id"
        }
      },
      "required": [
        "text",
        "language",
        "alias_type"
      ],
      "title": "ConceptAlias",
      "type": "object"
    },
    "ConceptRelation": {
      "additionalProperties": false,
      "properties": {
        "relation_id": {
          "pattern": "^rel_[a-f0-9]{12,64}$",
          "title": "Relation Id",
          "type": "string"
        },
        "source_concept_id": {
          "minLength": 1,
          "title": "Source Concept Id",
          "type": "string"
        },
        "relation_type": {
          "enum": [
            "is_a",
            "part_of",
            "causes",
            "risk_factor_for",
            "leads_to",
            "manifests_as",
            "diagnosed_by",
            "differentiated_from",
            "treated_by",
            "contraindicates",
            "complicated_by",
            "associated_with",
            "progresses_to",
            "measured_by",
            "located_in",
            "acts_on",
            "exam_confused_with",
            "discipline_view_of",
            "taught_in",
            "examined_in",
            "prerequisite_for",
            "clinically_connects_to",
            "pathology_basis_of",
            "pharmacologic_target_of",
            "imaging_correlate_of",
            "surgical_management_of"
          ],
          "title": "Relation Type",
          "type": "string"
        },
        "target_concept_id": {
          "minLength": 1,
          "title": "Target Concept Id",
          "type": "string"
        },
        "citations": {
          "items": {
            "type": "string"
          },
          "title": "Citations",
          "type": "array"
        },
        "confidence": {
          "anyOf": [
            {
              "maximum": 1,
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confidence"
        }
      },
      "required": [
        "relation_id",
        "source_concept_id",
        "relation_type",
        "target_concept_id"
      ],
      "title": "ConceptRelation",
      "type": "object"
    },
    "DisciplineLens": {
      "additionalProperties": false,
      "properties": {
        "lens_id": {
          "title": "Lens Id",
          "type": "string"
        },
        "concept_id": {
          "minLength": 1,
          "title": "Concept Id",
          "type": "string"
        },
        "discipline_id": {
          "title": "Discipline Id",
          "type": "string"
        },
        "course_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Course Id"
        },
        "focus_questions": {
          "items": {
            "type": "string"
          },
          "title": "Focus Questions",
          "type": "array"
        },
        "chapter_refs": {
          "items": {
            "type": "string"
          },
          "title": "Chapter Refs",
          "type": "array"
        },
        "knowledge_unit_refs": {
          "items": {
            "type": "string"
          },
          "title": "Knowledge Unit Refs",
          "type": "array"
        },
        "exam_point_refs": {
          "items": {
            "type": "string"
          },
          "title": "Exam Point Refs",
          "type": "array"
        },
        "discipline_summary": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Discipline Summary"
        }
      },
      "required": [
        "lens_id",
        "concept_id",
        "discipline_id"
      ],
      "title": "DisciplineLens",
      "type": "object"
    },
    "ExternalIdentifiers": {
      "additionalProperties": false,
      "properties": {
        "mesh": {
          "items": {
            "type": "string"
          },
          "title": "Mesh",
          "type": "array"
        },
        "snomed_ct": {
          "items": {
            "type": "string"
          },
          "title": "Snomed Ct",
          "type": "array"
        },
        "icd10": {
          "items": {
            "type": "string"
          },
          "title": "Icd10",
          "type": "array"
        },
        "loinc": {
          "items": {
            "type": "string"
          },
          "title": "Loinc",
          "type": "array"
        },
        "rxnorm": {
          "items": {
            "type": "string"
          },
          "title": "Rxnorm",
          "type": "array"
        }
      },
      "title": "ExternalIdentifiers",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.1.0",
      "default": "1.1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "concept_id": {
      "pattern": "^[a-z][a-z0-9_]{2,127}$",
      "title": "Concept Id",
      "type": "string"
    },
    "canonical_name": {
      "minLength": 1,
      "title": "Canonical Name",
      "type": "string"
    },
    "preferred_english": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Preferred English"
    },
    "concept_type": {
      "enum": [
        "disease",
        "syndrome",
        "symptom",
        "sign",
        "anatomy",
        "physiology",
        "pathology",
        "mechanism",
        "investigation",
        "imaging_sign",
        "drug",
        "procedure",
        "complication",
        "score",
        "guideline",
        "organism",
        "gene",
        "biomarker",
        "other"
      ],
      "title": "Concept Type",
      "type": "string"
    },
    "external_identifiers": {
      "$ref": "#/$defs/ExternalIdentifiers"
    },
    "aliases": {
      "items": {
        "$ref": "#/$defs/ConceptAlias"
      },
      "title": "Aliases",
      "type": "array"
    },
    "relations": {
      "items": {
        "$ref": "#/$defs/ConceptRelation"
      },
      "title": "Relations",
      "type": "array"
    },
    "discipline_lenses": {
      "items": {
        "$ref": "#/$defs/DisciplineLens"
      },
      "title": "Discipline Lenses",
      "type": "array"
    },
    "status": {
      "default": "active",
      "enum": [
        "active",
        "deprecated",
        "merged",
        "split_pending"
      ],
      "title": "Status",
      "type": "string"
    },
    "merged_into": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Merged Into"
    }
  },
  "required": [
    "concept_id",
    "canonical_name",
    "concept_type"
  ],
  "title": "ConceptEntity",
  "type": "object"
}
