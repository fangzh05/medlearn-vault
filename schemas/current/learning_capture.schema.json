{
  "$defs": {
    "AssessmentAttempt": {
      "additionalProperties": false,
      "description": "Conversation-local assessment result; it is not a verified answer key.",
      "properties": {
        "attempt_id": {
          "minLength": 1,
          "title": "Attempt Id",
          "type": "string"
        },
        "question_type": {
          "enum": [
            "single_choice",
            "multiple_choice",
            "true_false",
            "short_answer"
          ],
          "title": "Question Type",
          "type": "string"
        },
        "question_text": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Question Text"
        },
        "options": {
          "default": [],
          "items": {
            "$ref": "#/$defs/AssessmentOption"
          },
          "title": "Options",
          "type": "array"
        },
        "learner_answer": {
          "minLength": 1,
          "title": "Learner Answer",
          "type": "string"
        },
        "assistant_judged_answer": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assistant Judged Answer"
        },
        "verdict": {
          "enum": [
            "correct",
            "partial",
            "incorrect",
            "unresolved"
          ],
          "title": "Verdict",
          "type": "string"
        },
        "assistant_explanation": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Assistant Explanation"
        },
        "concept_ids": {
          "default": [],
          "items": {
            "pattern": "^concept_[a-f0-9]{32}$",
            "type": "string"
          },
          "title": "Concept Ids",
          "type": "array"
        },
        "question_message_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Question Message Ids",
          "type": "array"
        },
        "learner_answer_message_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Learner Answer Message Ids",
          "type": "array"
        },
        "feedback_message_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Feedback Message Ids",
          "type": "array"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        }
      },
      "required": [
        "attempt_id",
        "question_type",
        "learner_answer",
        "verdict",
        "learner_answer_message_ids",
        "observed_at"
      ],
      "title": "AssessmentAttempt",
      "type": "object"
    },
    "AssessmentOption": {
      "additionalProperties": false,
      "description": "One visible option from an assessment prompt, retained verbatim.",
      "properties": {
        "label": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Label",
          "type": "string"
        },
        "text": {
          "minLength": 1,
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "label",
        "text"
      ],
      "title": "AssessmentOption",
      "type": "object"
    },
    "ConceptMention": {
      "additionalProperties": false,
      "properties": {
        "surface_text": {
          "title": "Surface Text",
          "type": "string"
        },
        "candidate_concept_ids": {
          "default": [],
          "items": {
            "pattern": "^concept_[a-f0-9]{32}$",
            "type": "string"
          },
          "title": "Candidate Concept Ids",
          "type": "array"
        },
        "resolved_concept_id": {
          "anyOf": [
            {
              "pattern": "^concept_[a-f0-9]{32}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Resolved Concept Id"
        },
        "resolution_status": {
          "enum": [
            "resolved",
            "ambiguous",
            "new_candidate",
            "rejected"
          ],
          "title": "Resolution Status",
          "type": "string"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "message_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Message Ids",
          "type": "array"
        }
      },
      "required": [
        "surface_text",
        "resolution_status",
        "confidence"
      ],
      "title": "ConceptMention",
      "type": "object"
    },
    "ConversationExplanation": {
      "additionalProperties": false,
      "description": "Assistant-stated definition from the current learning chat, not verified knowledge.",
      "properties": {
        "concept_id": {
          "pattern": "^concept_[a-f0-9]{32}$",
          "title": "Concept Id",
          "type": "string"
        },
        "explanation_text": {
          "minLength": 1,
          "title": "Explanation Text",
          "type": "string"
        },
        "evidence_message_ids": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Evidence Message Ids",
          "type": "array"
        },
        "origin": {
          "const": "learning_chat",
          "default": "learning_chat",
          "title": "Origin",
          "type": "string"
        },
        "verification_status": {
          "const": "unverified_chat",
          "default": "unverified_chat",
          "title": "Verification Status",
          "type": "string"
        }
      },
      "required": [
        "concept_id",
        "explanation_text",
        "evidence_message_ids"
      ],
      "title": "ConversationExplanation",
      "type": "object"
    },
    "GeneratedExplanation": {
      "additionalProperties": false,
      "description": "Persisted GPT prose, deliberately separate from claims and chat evidence.",
      "properties": {
        "concept_id": {
          "pattern": "^concept_[a-f0-9]{32}$",
          "title": "Concept Id",
          "type": "string"
        },
        "explanation_text": {
          "minLength": 1,
          "title": "Explanation Text",
          "type": "string"
        },
        "origin": {
          "const": "gpt_generated",
          "default": "gpt_generated",
          "title": "Origin",
          "type": "string"
        },
        "verification_status": {
          "const": "unverified",
          "default": "unverified",
          "title": "Verification Status",
          "type": "string"
        },
        "generated_at": {
          "format": "date-time",
          "title": "Generated At",
          "type": "string"
        },
        "generator_id": {
          "minLength": 1,
          "title": "Generator Id",
          "type": "string"
        },
        "learning_session_id": {
          "minLength": 1,
          "title": "Learning Session Id",
          "type": "string"
        },
        "generation_context_digest": {
          "pattern": "^sha256:[a-f0-9]{64}$",
          "title": "Generation Context Digest",
          "type": "string"
        }
      },
      "required": [
        "concept_id",
        "explanation_text",
        "generated_at",
        "generator_id",
        "learning_session_id",
        "generation_context_digest"
      ],
      "title": "GeneratedExplanation",
      "type": "object"
    },
    "LearnerEvidence": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "title": "Evidence Id",
          "type": "string"
        },
        "concept_id": {
          "pattern": "^concept_[a-f0-9]{32}$",
          "title": "Concept Id",
          "type": "string"
        },
        "knowledge_unit_id": {
          "anyOf": [
            {
              "pattern": "^unit_[a-f0-9]{32}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Knowledge Unit Id"
        },
        "evidence_type": {
          "enum": [
            "correct_independent",
            "correct_after_hint",
            "guessed_correct",
            "partial",
            "unknown",
            "incorrect",
            "high_confidence_incorrect",
            "self_report_only"
          ],
          "title": "Evidence Type",
          "type": "string"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "rationale": {
          "title": "Rationale",
          "type": "string"
        },
        "message_id": {
          "title": "Message Id",
          "type": "string"
        },
        "user_excerpt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "User Excerpt"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "concept_id",
        "evidence_type",
        "confidence",
        "rationale",
        "message_id",
        "observed_at"
      ],
      "title": "LearnerEvidence",
      "type": "object"
    },
    "MisconceptionObservation": {
      "additionalProperties": false,
      "properties": {
        "observation_id": {
          "title": "Observation Id",
          "type": "string"
        },
        "concept_ids": {
          "items": {
            "pattern": "^concept_[a-f0-9]{32}$",
            "type": "string"
          },
          "title": "Concept Ids",
          "type": "array"
        },
        "discipline_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Discipline Ids",
          "type": "array"
        },
        "observed_error_logic": {
          "title": "Observed Error Logic",
          "type": "string"
        },
        "proposed_correction": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Proposed Correction"
        },
        "correction_claim_ids": {
          "default": [],
          "items": {
            "pattern": "^claim_[a-f0-9]{32}$",
            "type": "string"
          },
          "title": "Correction Claim Ids",
          "type": "array"
        },
        "severity": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Severity",
          "type": "string"
        },
        "evidence_message_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Message Ids",
          "type": "array"
        },
        "user_excerpt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "User Excerpt"
        },
        "observed_at": {
          "format": "date-time",
          "title": "Observed At",
          "type": "string"
        }
      },
      "required": [
        "observation_id",
        "concept_ids",
        "observed_error_logic",
        "severity",
        "evidence_message_ids",
        "observed_at"
      ],
      "title": "MisconceptionObservation",
      "type": "object"
    },
    "OpenQuestion": {
      "additionalProperties": false,
      "properties": {
        "question_id": {
          "title": "Question Id",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "concept_ids": {
          "items": {
            "pattern": "^concept_[a-f0-9]{32}$",
            "type": "string"
          },
          "title": "Concept Ids",
          "type": "array"
        },
        "discipline_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Discipline Id"
        },
        "priority": {
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "title": "Priority",
          "type": "string"
        }
      },
      "required": [
        "question_id",
        "text",
        "concept_ids",
        "priority"
      ],
      "title": "OpenQuestion",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.2.0",
      "default": "1.2.0",
      "title": "Schema Version",
      "type": "string"
    },
    "session_id": {
      "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
      "title": "Session Id",
      "type": "string"
    },
    "source_id": {
      "pattern": "^source_[a-f0-9]{32}$",
      "title": "Source Id",
      "type": "string"
    },
    "session_started_at": {
      "format": "date-time",
      "title": "Session Started At",
      "type": "string"
    },
    "captured_at": {
      "format": "date-time",
      "title": "Captured At",
      "type": "string"
    },
    "discipline_id": {
      "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
      "title": "Discipline Id",
      "type": "string"
    },
    "course_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Course Id"
    },
    "chapter_id": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_:-]{2,127}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Chapter Id"
    },
    "concept_mentions": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ConceptMention"
      },
      "title": "Concept Mentions",
      "type": "array"
    },
    "learner_evidence": {
      "default": [],
      "items": {
        "$ref": "#/$defs/LearnerEvidence"
      },
      "title": "Learner Evidence",
      "type": "array"
    },
    "misconception_observations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/MisconceptionObservation"
      },
      "title": "Misconception Observations",
      "type": "array"
    },
    "open_questions": {
      "default": [],
      "items": {
        "$ref": "#/$defs/OpenQuestion"
      },
      "title": "Open Questions",
      "type": "array"
    },
    "assessment_attempts": {
      "default": [],
      "items": {
        "$ref": "#/$defs/AssessmentAttempt"
      },
      "title": "Assessment Attempts",
      "type": "array"
    },
    "generated_explanations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/GeneratedExplanation"
      },
      "title": "Generated Explanations",
      "type": "array"
    },
    "conversation_explanations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ConversationExplanation"
      },
      "title": "Conversation Explanations",
      "type": "array"
    }
  },
  "required": [
    "session_id",
    "source_id",
    "session_started_at",
    "captured_at",
    "discipline_id"
  ],
  "title": "LearningCapture",
  "type": "object"
}
